# Скопируйте значения в .env (база) и .env.local (вход) и подставьте свои.

# ── База данных (Supabase / PostgreSQL) ──
# Supabase → Connect → Session pooler (порт 5432):
DATABASE_URL="postgresql://postgres.ССЫЛКА:ПАРОЛЬ@aws-0-РЕГИОН.pooler.supabase.com:5432/postgres"

# ── Вход преподавателя ──
APP_PASSWORD="придумайте-пароль-для-входа"
# AUTH_SECRET — длинная случайная строка для подписи сессии (openssl rand -hex 32)
AUTH_SECRET="смените-на-случайную-строку"
