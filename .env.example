# Скопируйте этот файл в .env и подставьте свои значения.
# Локально (прототип) — SQLite:
DATABASE_URL="file:./dev.db"

# Продакшн (Supabase / Postgres) — строка подключения вида:
# DATABASE_URL="postgresql://postgres:ПАРОЛЬ@ХОСТ:5432/postgres"

# Вход преподавателя:
APP_PASSWORD="придумайте-пароль-для-входа"
# AUTH_SECRET — длинная случайная строка для подписи сессии (openssl rand -hex 32)
AUTH_SECRET="смените-на-случайную-строку"
